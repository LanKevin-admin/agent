# ========== AI配置（必填）==========
# 请在 https://platform.deepseek.com/ 获取API Key
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_API_BASE=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ========== 飞书配置（可选）==========
# 飞书开放平台创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 飞书群聊的Chat ID（通过API获取）
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 邮箱配置（可选）==========
# SMTP服务器配置
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_email@163.com
# 注意：这里填的是SMTP授权码，不是邮箱密码
SMTP_PASSWORD=your_smtp_auth_code

# 接收报告的邮箱（多个用逗号分隔）
BUSINESS_EMAILS=business1@example.com,business2@example.com
TECH_EMAILS=tech1@example.com,tech2@example.com

# ========== 企业微信配置（可选）==========
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

# ========== 定时任务配置 ==========
# 每日默认执行时间（24小时制）
DAILY_RUN_HOUR=20
DAILY_RUN_MINUTE=0

# ========== 报告输出配置 ==========
# 留空则使用默认值（EXE同目录的reports文件夹）
REPORT_OUTPUT_DIR=
